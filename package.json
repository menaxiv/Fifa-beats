{
  "name": "beats",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "emulators": "docker compose up",
    "emulators:down": "docker compose down",
    "dev:all": "concurrently \"npm run emulators\" \"npm run dev\"",
    "deploy": "npm run build && firebase deploy",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:functions": "cd functions && npm run build && cd .. && firebase deploy --only functions",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed:wc": "cd scripts && npm install --silent && npm run seed:wc",
    "seed:nfl": "cd scripts && npm install --silent && npm run seed:nfl",
    "seed:wbc": "cd scripts && npm install --silent && npm run seed:wbc"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "firebase": "^12.14.0",
    "fuse.js": "^7.4.2",
    "lucide-react": "^0.468.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.78.0",
    "react-router-dom": "^7.0.0",
    "sonner": "^1.7.4",
    "zod": "^3.25.76",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@hookform/resolvers": "^3.10.0",
    "@tailwindcss/vite": "^4.1.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "concurrently": "^9.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^4.1.0",
    "tw-animate-css": "^1.2.5",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
